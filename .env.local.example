# ──────────────────────────────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────────────────────────────
# LinkedIn
# ──────────────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/linkedin/oauth/callback

# ──────────────────────────────────────────────────────────────────────
# Threads (Meta Developer Portal)
# Create app at https://developers.facebook.com/apps
#   - Add product: Threads API
#   - Scopes: threads_basic, threads_content_publish
#   - OAuth redirect: http://localhost:3000/api/threads/oauth/callback
# ──────────────────────────────────────────────────────────────────────
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=
THREADS_REDIRECT_URI=http://localhost:3000/api/threads/oauth/callback

# ──────────────────────────────────────────────────────────────────────
# Instagram (Facebook Graph API)
# Same Meta Developer Portal as Threads (can use a single app or separate)
#   - Add product: Instagram Graph API + Facebook Login
#   - Scopes: instagram_basic, instagram_content_publish, pages_show_list,
#             pages_read_engagement, business_management
#   - OAuth redirect: http://localhost:3000/api/instagram/oauth/callback
# Note: User's Instagram account must be Business/Creator + linked to a FB Page
# ──────────────────────────────────────────────────────────────────────
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/instagram/oauth/callback

# ──────────────────────────────────────────────────────────────────────
# Crypto (32 bytes hex = 64 chars) — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ──────────────────────────────────────────────────────────────────────
TOKEN_ENCRYPTION_KEY=

# ──────────────────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
